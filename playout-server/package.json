{
  "name": "newsforge-playout",
  "version": "1.0.0",
  "description": "News Forge Standalone Playout Server",
  "scripts": {
    "dev": "concurrently \"tsx watch server.ts\" \"vite\"",
    "build": "vite build && tsc server.ts --outDir dist",
    "start": "tsx server.ts"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "lucide-react": "^0.460.0"
  }
}
